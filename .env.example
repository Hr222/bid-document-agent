# 应用基础配置
APP_NAME=Bid Document Agent
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1
POLICY_PIPELINE_WORKSPACE=.runtime/policy_pipeline

# 数据库配置
# 如果设置了 DATABASE_URL，会优先使用它，并覆盖下面的 POSTGRES_* 分项配置。
DATABASE_URL=
POSTGRES_DRIVER=postgresql+psycopg
POSTGRES_DB=bid_document_agent
POSTGRES_USER=admin
POSTGRES_PASSWORD=123456
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# 模型相关配置
GITEE_API_KEY=
GITEE_BASE_URL=https://ai.gitee.com/v1
EMBEDDING_MODEL=Qwen3-Embedding-0.6B
VECTOR_DIMENSIONS=1024
