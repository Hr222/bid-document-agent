# 应用基础配置
APP_NAME=Go Agent System
APP_VERSION=0.1.0
BACKEND_HOST=127.0.0.1
BACKEND_PORT=9205
API_V1_PREFIX=/api/v1
POLICY_PIPELINE_WORKSPACE=.runtime/policy_pipeline

# 上传暂存大小上限和保留时间，分别按字节和秒配置。
POLICY_UPLOAD_MAX_SIZE_BYTES=52428800
POLICY_UPLOAD_RETENTION_SECONDS=86400

# 数据库配置
# 如果设置了 DATABASE_URL，会优先使用它，并覆盖下面的 POSTGRES_* 分项配置。
DATABASE_URL=
POSTGRES_DRIVER=postgresql+psycopg
POSTGRES_DB=go_agent_system
POSTGRES_USER=admin
POSTGRES_PASSWORD=123456
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

#embedding模型相关配置
GITEE_API_KEY=
GITEE_BASE_URL=https://ai.gitee.com/v1
EMBEDDING_MODEL=Qwen3-Embedding-0.6B
VECTOR_DIMENSIONS=1024

#LLM接入
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_CHAT_MODEL=glm-4.7
ZHIPU_TIMEOUT_SECONDS=60
ZHIPU_TEMPERATURE=0
ZHIPU_MAX_TOKENS=

#OCR设定
OCR_PROVIDER=tencent
OCR_MODEL=glm-4.6v-flash
OCR_MAX_PAGES_PER_BATCH=4
OCR_IMAGE_MAX_SIDE=1800
OCR_TIMEOUT_SECONDS=60
OCR_REQUEST_INTERVAL_SECONDS=10
OCR_ENABLED=true

# 腾讯 OCR
TENCENT_OCR_SECRET_ID=
TENCENT_OCR_SECRET_KEY=
TENCENT_OCR_REGION=ap-guangzhou
TENCENT_OCR_ENDPOINT=ocr.tencentcloudapi.com
TENCENT_OCR_ACTION=GeneralAccurateOCR
# OCR 输出只允许写入运行时目录，禁止写入 tests，避免敏感识别结果进入仓库。
TENCENT_OCR_OUTPUT_ROOT=.runtime/ocr_output
TENCENT_OCR_DOCX_IMAGE_LIMIT=50
TENCENT_OCR_PDF_PAGE_LIMIT=0

#RAG召回
RETRIEVAL_TOP_K_DEFAULT=5
RETRIEVAL_TOP_K_MAX=20
VECTOR_SEARCH_STRATEGY=exact
VECTOR_SEARCH_HNSW_M=16
VECTOR_SEARCH_HNSW_EF_CONSTRUCTION=64
VECTOR_SEARCH_HNSW_EF_SEARCH=40
RAG_ANSWER_TOP_K=6
RAG_MAX_CONTEXT_CHARS_PER_CHUNK=500
